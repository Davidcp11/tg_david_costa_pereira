{
    "data": {
        "data_dpath": "/Users/davidcostapereira/work/ITA/TG/TG/data/kitti",
        "dataset": "kitti",
        "dataset_name_norm": "kitti",
        "normalize_gt": true,
        "estimate_depth": true,
        "training_sequences": ["00", "02", "08"],
        "test_sequences": ["09"],
        "bsize": 2,
        "val_split": 0.1,
        "window_size": 3,
        "overlap": 2,
        "num_workers": 0
    },

    "model": {
        "spm": true,
        "DEIT_size": "custom",
        "patch_size": 16,
        "embed_dim": 384,
        "depth": 6,
        "num_heads": 12,
        "image_size": [192, 640],
        "attention_type": "divided_space_time",
        "dim_head": 256,
        "attn_dropout": 0.1,
        "ff_dropout": 0.1,
        "pretrained_ViT": false,
        "vit_layers": [0, 1, 2, 3]
    },

    "optimizer": {
        "method": "AdamW",
        "lr": 1e-4,
        "momentum": 0.9,
        "weight_decay": 1e-4
    },

    "scheduler": {
        "method": "OneCycleLR"
    },

    "training": {
        "epoch": 2,
        "pose_loss": "camera_pose_loss",
        "lambda_t": -1.0,
        "lambda_rot": -1.0,
        "depth_loss": "ssi_loss",
        "ssi_alpha": 0.5
    },

    "checkpoint": {
        "checkpoint_dpath": "checkpoints/kitti",
        "model_init_fpath": null
    }
}
