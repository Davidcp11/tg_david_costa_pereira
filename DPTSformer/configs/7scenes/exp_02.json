{
    "data": {
        "data_dpath": "C:/workspace/data/7scenes",
        "dataset": "7scenes",
        "normalize_gt": false,
        "estimate_depth": false,
        "read_depth": true,
        "dataset_name_norm": "7scenes",
        "bsize": 8,
        "val_split": 0.1,
        "window_size": 3,
        "overlap": 2,
        "num_workers": 4
    },

    "model": {
        "spm": true,
        "DEIT_size": "custom",
        "patch_size": 16,
        "embed_dim": 384,
        "depth": 9,
        "num_heads": 12,
        "image_size": [128, 160],
        "attention_type": "divided_space_time",
        "dim_head": 256,
        "attn_dropout": 0.1,
        "ff_dropout": 0.1,
        "pretrained_ViT": false,
        "vit_layers": [1, 3, 5, 6]
    },

    "optimizer": {
        "method": "AdamW",
        "lr": 1e-4,
        "momentum": 0.9,
        "weight_decay": 1e-4
    },

    "scheduler": {
        "method": "OneCycleLR"
    },
    
    "training": {
        "epoch": 150,
        "pose_loss": "camera_pose_loss",  
        "lambda_t": 0.0,
        "lambda_rot": -3.0,
        "depth_loss": "ssi_loss",
        "ssi_alpha": 0.5
    },

    "checkpoint": {
        "checkpoint_dpath": "checkpoints/7scenes",
        "model_init_fpath": null
    }
}